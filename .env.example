# Copy to .env and fill in your Cloudflare R2 test bucket credentials.
# .env is gitignored — never commit real credentials.
#
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
#   → Create Account API token → Object Read & Write, scoped to your bucket.
# Use the Access Key ID + Secret Access Key (NOT the cfat_… API token).

R2OFFLOAD_ACCOUNT_ID=your-account-id
R2OFFLOAD_BUCKET=your-bucket-name
R2OFFLOAD_ACCESS_KEY=your-access-key-id
R2OFFLOAD_SECRET_KEY=your-secret-access-key
R2OFFLOAD_CUSTOM_DOMAIN=
